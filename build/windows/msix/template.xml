<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="Pigeon.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Atterpac\Pigeon">
    </Installer>
    <PackageInformation
        PackageName="Pigeon"
        PackageDisplayName="Pigeon"
        PublisherName="CN=Atterpac"
        PublisherDisplayName="Atterpac"
        Version="0.1.0.0"
        PackageDescription="A keyboard focused email client">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="Pigeon"
                Description="A keyboard focused email client"
                DisplayName="Pigeon"
                ExecutableName="Pigeon.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Pigeon</DisplayName>
            <PublisherDisplayName>Atterpac</PublisherDisplayName>
            <Description>A keyboard focused email client</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="Pigeon.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
